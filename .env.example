# Interceptor — Development Environment
# See README.md for setup instructions

# Runtime
NODE_ENV=development

# Database (Postgres + TimescaleDB) — required.
# Spin up the container with: docker compose up -d postgres
# Host port is 5434 because 5432 / 5433 are typically already bound on dev machines.
DATABASE_URL=postgres://interceptor:interceptor@localhost:5434/interceptor

# UFC Fight Predictor
ODDS_API_KEY=
# ADMIN_SECRET=
