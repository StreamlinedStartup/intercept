{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": ["DATABASE_URL"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"typecheck": {
			"outputs": []
		}
	}
}
