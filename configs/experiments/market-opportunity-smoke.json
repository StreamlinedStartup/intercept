{
  "name": "market-opportunity-smoke",
  "description": "Small report-only smoke matrix for moneyline, decision, finish, and abstain opportunity selectors.",
  "value_status": "research_only",
  "report_only": true,
  "writes_model_versions": false,
  "corpus": {
    "source": "matched_market_fights",
    "market_source": "fightodds_no_vig_consensus",
    "min_train_samples": 20,
    "max_events": 6
  },
  "split": {
    "policy": "chronological_walk_forward",
    "candidate_selection": "discovery_slice",
    "locked_evaluation": "future_required"
  },
  "gate": {
    "baseline": "market_favorite",
    "min_roi_delta_vs_market": 0.02,
    "probability_quality": {
      "require_log_loss_not_worse": true,
      "require_brier_not_worse": true
    }
  },
  "variants": [
    {
      "name": "market_favorite",
      "model": "market_favorite",
      "target": "winner",
      "features": "none",
      "market_blend_weight": null,
      "description": "No-vig market favorite baseline."
    },
    {
      "name": "winner_underdog_edge_smoke",
      "model": "logistic_regression",
      "target": "winner",
      "features": "production_plus_market_context",
      "market_blend_weight": null,
      "selection_policy": {
        "type": "undervalued_underdog",
        "threshold": 0.05
      },
      "description": "Smoke check for model-selected underdogs with positive model-vs-market edge."
    },
    {
      "name": "decision_edge_smoke",
      "model": "logistic_regression",
      "target": "decision",
      "features": "production_plus_all_research",
      "selection_policy": {
        "type": "decision_edge",
        "threshold": 0.6
      },
      "description": "Smoke check for fights with elevated model decision probability."
    },
    {
      "name": "finish_edge_smoke",
      "model": "logistic_regression",
      "target": "finish",
      "features": "production_plus_all_research",
      "selection_policy": {
        "type": "finish_edge",
        "threshold": 0.6
      },
      "description": "Smoke check for fights with elevated model finish probability."
    },
    {
      "name": "winner_abstain_smoke",
      "model": "logistic_regression",
      "target": "winner",
      "features": "production_plus_market_context",
      "selection_policy": {
        "type": "abstain",
        "threshold": 0.55
      },
      "description": "Smoke check for pass rows where model confidence is too thin."
    }
  ],
  "outputs": {
    "json": "data/experiments/harness/market-opportunity-smoke.json",
    "markdown": "data/experiments/harness/market-opportunity-smoke.md"
  }
}
